  "question_types": [
    {
      "id": "short_answer",
      "label": "簡答",
      "fields": {
        "required": [
          "id",
          "topic",
          "question",
          "answer"
        ],
        "optional": [
          "layer"
        ]
      },
      "description": "開放式問答、answer 為範例解答字串"
    },
    {
      "id": "multiple_choice",
      "label": "選擇",
      "fields": {
        "required": [
          "id",
          "topic",
          "question",
          "options",
          "correct",
          "explanation"
        ],
        "optional": [
          "layer"
        ]
      },
      "description": "options 為 {A,B,C,D} 字典、correct 為單一字母",
      "notes": "正解 A/B/C/D 分布已做 block randomization、連續相同≤2 題"
    },
    {
      "id": "essay",
      "label": "申論",
      "fields": {
        "required": [
          "id",
          "topic",
          "question",
          "key_points",
          "model_answer"
        ],
        "optional": [
          "layer"
        ]
      },
      "description": "key_points 為評分要點陣列、model_answer 為完整範文字串"
    },
    {
      "id": "calculation",
      "label": "計算",
      "fields": {
        "required": [
          "id",
          "topic",
          "question",
          "given",
          "steps",
          "answer",
          "unit"
        ],
        "optional": [
          "layer"
        ]
      },
      "description": "given 為條件字典、steps 為解題步驟陣列、answer 為最終答案、unit 為單位",
      "notes": "所有難度（含地獄）已統一為此結構"
    },
    {
      "id": "word_game",
      "label": "一字千金",
      "fields": {
        "required": [
          "id",
          "topic",
          "word",
          "options",
          "correct"
        ],
        "optional": [
          "context_phrase",
          "scenario",
          "meaning"
        ]
      },
      "description": "word 為字、options 為 4 個注音字串陣列、correct 為正確注音字串（非位置）",
      "notes": "正解位置分布已做 block randomization"
    }
  ],
